@page "/customers"

@using MiniERP.Blazor.Models
@using MiniERP.Blazor.Services

@inject CustomerService CustomerService

<h2 class="mb-4">Customers</h2>

<div class="card shadow-sm">

    <div class="card-header d-flex justify-content-between align-items-center">

        <a href="/customers/create"
           class="btn btn-primary">

            <i class="bi bi-plus-lg"></i>

            Add Customer

        </a>

        <div class="d-flex">

            <input class="form-control"

                   placeholder="Search..."

                   @bind="search"

                   @bind:event="oninput" />

            <button class="btn btn-outline-primary ms-2"

                    @onclick="LoadCustomers">

                Search

            </button>

        </div>

    </div>

    <div class="card-body">

        <table class="table table-hover">

            <thead>

                <tr>

                    <th>Name</th>

                    <th>Phone</th>

                    <th>Email</th>

                    <th>Address</th>

                    <th>Actions</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in result.Items)
                {
                    <tr>

                        <td>@item.FullName</td>

                        <td>@item.PhoneNumber</td>

                        <td>@item.Email</td>

                        <td>@item.Address</td>

                        <td>

                            <a class="btn btn-warning btn-sm"

                               href="/customers/edit/@item.Id">

                                <i class="bi bi-pencil"></i>

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <div class="d-flex justify-content-between mt-3">

            <button class="btn btn-outline-primary"

                    @onclick="PreviousPage"

                    disabled="@(currentPage==1)">

                Previous

            </button>

            <span>

                Page @result.Page of @result.TotalPages

            </span>

            <button class="btn btn-outline-primary"

                    @onclick="NextPage"

                    disabled="@(currentPage==result.TotalPages)">

                Next

            </button>

        </div>

    </div>

</div>

@code {

    private string search = "";

    private int currentPage = 1;

    private int pageSize = 10;

    private PagedResult<CustomerDto> result = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomers();
    }

    private async Task LoadCustomers()
    {
        result = await CustomerService.GetCustomersAsync(
            currentPage,
            pageSize,
            search);
    }

    private async Task NextPage()
    {
        if (currentPage >= result.TotalPages)
            return;

        currentPage++;

        await LoadCustomers();
    }

    private async Task PreviousPage()
    {
        if (currentPage <= 1)
            return;

        currentPage--;

        await LoadCustomers();
    }

}