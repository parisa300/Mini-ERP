@using MiniERP.Blazor.Models

<div class="card shadow-sm h-100">

    <div class="card-header bg-white">

        <h5 class="mb-0">

            ⚠️ Low Stock Alerts

        </h5>

    </div>

    <div class="card-body">

        @if (Products.Count == 0)
        {
            <p class="text-muted">

                Everything looks good 🎉

            </p>
        }
        else
        {
            <table class="table table-hover">

                <thead>

                    <tr>

                        <th>Product</th>

                        <th>Warehouse</th>

                        <th class="text-end">

                            Qty

                        </th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Products)
                    {
                        <tr>

                            <td>

                                @item.ProductName

                            </td>

                            <td>

                                @item.WarehouseName

                            </td>

                            <td class="text-end">

                                <span class="badge bg-danger">

                                    @item.Quantity

                                </span>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>
        }

    </div>

</div>

@code{

    [Parameter]

    public List<LowStockDto> Products { get; set; } = [];

}